  "version": "0.2.0",
  "configurations": [
    {
      "name": "Validator",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/neurons/validator.py",
      "console": "integratedTerminal",
      "args": [
        "--netuid 1",
        "--subtensor.chain_endpoint",
        "ws://127.0.0.1:9946",
        "--wallet.name",
        "validator",
        "--wallet.hotkey",
        "default",
        "--logging.debug"
      ],
      "justMyCode": false
    },
    {
      "name": "Miner",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/neurons/validator.py",
      "console": "integratedTerminal",
      "args": [
        "--netuid 1",
        "--subtensor.chain_endpoint",
        "ws://127.0.0.1:9946",
        "--wallet.name",
        "miner",
        "--wallet.hotkey",
        "default",
        "--logging.debug"
      ]
    }
  ]
}
